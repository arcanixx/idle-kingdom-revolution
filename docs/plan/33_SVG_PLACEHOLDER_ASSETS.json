  \"style_guidelines\": {
    \"design_philosophy\": \"Geometric minimalism - clear shapes, no tiny details\",
    \"viewbox_standards\": {
      \"units_items_emotions\": \"0 0 64 64\",
      \"bosses\": \"0 0 128 128\", 
      \"backgrounds\": \"0 0 1920 1080\"
    },
    \"color_strategy\": \"Faction primary color dominant, symbol in contrasting secondary color\",
    \"line_thickness\": \"stroke-width=\\\"2\\\" for visibility at small sizes\",
    \"background\": \"transparent (fill=\\\"none\\\") for all assets\",
    \"avoid\": \"Tiny details, complex gradients, photorealistic elements\"
  },

  \"generation_prompt_template\": \"Generate minimal SVG placeholder for fantasy [TYPE] named [NAME]. Style: flat design, geometric shapes, clear visibility at small sizes. ViewBox: [VIEWBOX]. Colors: Use faction colors for units, generic colors for items. Symbols: Simple geometric shapes representing the concept. Include: Clear silhouette, no tiny details, scalable. Output: Raw SVG code with no comments.\",

